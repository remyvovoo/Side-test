# Clé de l'API remove.bg — jamais codée en dur dans le code, uniquement ici.
# Régénère une clé sur https://www.remove.bg/dashboard puis colle-la dans un .env.local (non versionné).
REMOVE_BG_KEY=

# Base de données Postgres (Vercel Storage → Create Database → Postgres).
DATABASE_URL=

# Secret utilisé pour signer les sessions — génère-en un avec `openssl rand -base64 32`.
AUTH_SECRET=
